rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBootstrapAdmin() {
      return request.auth != null &&
        request.auth.uid == 'kaqcXOcHHYU7VeSXdLMUR2E66vB3';
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User documents & sub-collections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isBootstrapAdmin();
      allow write: if isBootstrapAdmin() || isAdmin() ||
        (isOwner(userId) && (
          !('role' in request.resource.data) ||
          request.resource.data.role == resource.data.role
        ));

      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrapAdmin();
      }
    }

    // Admin collectionGroup read + delete across all user invoices
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isAdmin() || isBootstrapAdmin();
      allow delete: if isAdmin() || isBootstrapAdmin();
    }

    // Announcements — authenticated users read, admin writes
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // Premium access codes — admin manages; users can read a specific code by ID only
    // (prevents full enumeration; client looks up a code by its ID to validate)
    match /premium_codes/{codeId} {
      allow get: if request.auth != null;
      allow list: if isAdmin() || isBootstrapAdmin();
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // Premium users — each user can only create/update their own record (docId == uid)
    match /premium_users/{docId} {
      allow read: if isAdmin() || isBootstrapAdmin() || isOwner(docId);
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update: if isOwner(docId) || isAdmin() || isBootstrapAdmin();
      allow delete: if isAdmin() || isBootstrapAdmin();
    }
  }
}
