rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isBootstrapAdmin() {
      return request.auth != null &&
        request.auth.uid == 'kaqcXOcHHYU7VeSXdLMUR2E66vB3';
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isBootstrapAdmin();
      allow write: if isBootstrapAdmin() || isAdmin() ||
        (isOwner(userId) && (
          !('role' in request.resource.data) ||
          request.resource.data.role == resource.data.role
        ));

      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrapAdmin();
      }
    }

    // Admin collectionGroup read across all user invoices
    match /{path=**}/invoices/{invoiceId} {
      allow read: if isAdmin() || isBootstrapAdmin();
    }

    // Announcements — authenticated users read, admin writes
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }
  }
}
