rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────────

    /**
     * Bootstrap admin: a single hardcoded UID that can never lose admin access.
     * Used only during initial setup / emergency access.
     */
    function isBootstrapAdmin() {
      return request.auth != null &&
        request.auth.uid == 'kaqcXOcHHYU7VeSXdLMUR2E66vB3';
    }

    /**
     * RBAC admin: any user whose Firestore document has role == 'admin'.
     * NOTE: This performs one extra document read per rule evaluation.
     * Consider migrating to Firebase Auth Custom Claims to eliminate the read cost.
     */
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** Returns true when the authenticated user's UID matches the given userId. */
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── users/{userId} ───────────────────────────────────────────────────────
    //
    // Stores: profile, settings, isPremium, role, invoiceCount, totalRevenue, …
    //
    // Security intent:
    //   • Users can read and update their own document, but cannot escalate
    //     their own role field (prevents self-promotion to admin).
    //   • Users can create their own document on signup, but cannot include a
    //     role field in the initial payload.
    //   • Only admins can delete user documents or set arbitrary role values.
    //
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isBootstrapAdmin();

      // CREATE: owner may create their own doc, but must not include a role field.
      allow create: if isBootstrapAdmin() || isAdmin() ||
        (isOwner(userId) && !('role' in request.resource.data));

      // UPDATE: owner may update their own doc as long as they do not change
      // the role field. Admins may change any field including role.
      allow update: if isBootstrapAdmin() || isAdmin() ||
        (isOwner(userId) && (
          !('role' in request.resource.data) ||
          request.resource.data.role == resource.data.role
        ));

      // DELETE: admin-only; regular users cannot delete their own account doc.
      allow delete: if isAdmin() || isBootstrapAdmin();

      // ── users/{userId}/invoices/{invoiceId} ─────────────────────────────────
      //
      // Per-user invoice subcollection.
      // Users have full CRUD on their own invoices; admins can do anything.
      //
      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId) || isAdmin() || isBootstrapAdmin();
      }
    }

    // ─── collectionGroup: invoices ────────────────────────────────────────────
    //
    // Admin-only cross-user query via collectionGroup('invoices').
    // Used in the admin panel to list and delete invoices across all users.
    // The per-user nested rule above already covers owner+admin access for
    // direct path access; this rule adds collectionGroup read + delete for admins.
    //
    match /{path=**}/invoices/{invoiceId} {
      allow read:   if isAdmin() || isBootstrapAdmin();
      allow delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── announcements/{announcementId} ──────────────────────────────────────
    //
    // App-wide notices pushed by admins.
    // All authenticated users can read; only admins can create/update/delete.
    //
    match /announcements/{announcementId} {
      allow read:                  if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── premiumCodes/{codeId} ────────────────────────────────────────────────
    //
    // Access codes managed by admins. The document ID IS the code string
    // (e.g. "PREMIUM2026") so users can validate a code with a single-doc GET
    // instead of a collection query (which would require list permission).
    //
    // Security:
    //   • Authenticated users may GET a single code by ID (to validate/redeem).
    //   • Authenticated users may NOT list all codes (prevents enumeration).
    //   • Only admins may create, update, or delete codes.
    //
    match /premiumCodes/{codeId} {
      allow get:                   if request.auth != null;
      allow list:                  if isAdmin() || isBootstrapAdmin();
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── premium_codes/{codeId} (legacy — kept for read compatibility) ────────
    match /premium_codes/{codeId} {
      allow get:                   if request.auth != null;
      allow list:                  if isAdmin() || isBootstrapAdmin();
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── premium_users/{docId} ────────────────────────────────────────────────
    //
    // Records code redemptions. Document ID MUST equal the user's Firebase UID
    // so that the create rule (request.auth.uid == docId) can be enforced without
    // an extra document lookup.
    //
    // Security:
    //   • A user may create their own redemption record (docId == uid).
    //   • A user may read and update their own record.
    //   • Only admins may delete redemption records.
    //   • Admins can read/list all records.
    //
    match /premium_users/{docId} {
      allow read:   if isOwner(docId) || isAdmin() || isBootstrapAdmin();
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update: if isOwner(docId) || isAdmin() || isBootstrapAdmin();
      allow delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── premium_plans / invoice_templates / app_banners ─────────────────────
    //
    // Admin-managed catalog data. All authenticated users can read (so the
    // app can display plans/templates/banners); only admins can write.
    //
    match /premium_plans/{planId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    match /invoice_templates/{templateId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    match /app_banners/{bannerId} {
      allow read:                   if request.auth != null;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── notifications/{notificationId} ──────────────────────────────────────
    //
    // Push notification history/records. Admin-only — this is an internal
    // audit trail, not something regular users need to read.
    //
    match /notifications/{notificationId} {
      allow read, create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── feedback/{feedbackId} ────────────────────────────────────────────────
    //
    // Users submit their own feedback; only admins can list/manage all of it.
    //
    match /feedback/{feedbackId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get:    if isOwner(resource.data.userId) || isAdmin() || isBootstrapAdmin();
      allow list:   if isAdmin() || isBootstrapAdmin();
      allow update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── app_config/{docId} ───────────────────────────────────────────────────
    //
    // Legacy path — kept for read compatibility with any existing references.
    // New code uses appSettings instead.
    //
    match /app_config/{docId} {
      allow read:                   if true;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── appSettings/{docId} ─────────────────────────────────────────────────
    //
    // Active remote app settings collection (maintenance mode, version gates,
    // contact info, URLs). Readable by everyone (maintenance banner can show
    // before login); only admins can write.
    //
    match /appSettings/{docId} {
      allow read:                   if true;
      allow create, update, delete: if isAdmin() || isBootstrapAdmin();
    }

    // ─── invoices/{invoiceId} ────────────────────────────────────────────────
    //
    // Root-level invoices collection. Admins can list and delete all invoices.
    // Users can only read their own invoices (matched by userId field).
    // Note: the per-user subcollection (users/{uid}/invoices) is governed by
    // the nested match above; this rule covers the root collection.
    //
    match /invoices/{invoiceId} {
      allow read:   if isAdmin() || isBootstrapAdmin() ||
                       (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin() || isBootstrapAdmin() ||
                       (request.auth != null && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isBootstrapAdmin();
    }
  }
}
